{
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/proxy.js"
    },
    {
      "source": "/minio/:path*",
      "destination": "/api/proxy.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
    
    {
  "git": {
    "deploymentEnabled": false
  }
}

  ]
  
}
